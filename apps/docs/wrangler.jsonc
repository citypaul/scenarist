{
  "main": "./worker.js",
  "name": "scenarist",
  "compatibility_date": "2025-11-10",
  "compatibility_flags": [
    "nodejs_compat",
    "disable_nodejs_process_v2",
    "global_fetch_strictly_public",
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "./dist/client",
    "run_worker_first": true,
  },
  "observability": {
    "enabled": true,
  },
  "workers_dev": true,
}
